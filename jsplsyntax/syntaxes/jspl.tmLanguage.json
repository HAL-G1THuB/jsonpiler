{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JSPL",
  "scopeName": "source.jspl",
  "patterns": [
    {
      "include": "#definition"
    },
    {
      "include": "#statement"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.jspl",
      "match": "\\s*#.*$"
    },
    "statement": {
      "patterns": [
        {
          "include": "#all_expressions"
        }
      ]
    },
    "definition": {
      "begin": "\\b(define)\\s*\\(\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.jspl"
        },
        "2": {
          "name": "entity.name.function.jspl"
        }
      },
      "end": "\\)",
      "patterns": [
        {
          "include": "#all_expressions"
        },
        {
          "match": ",",
          "name": "punctuation.separator.jspl"
        }
      ]
    },
    "all_expressions": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#call"
        },
        {
          "include": "#type_primitive"
        },
        {
          "include": "#constant"
        },
        {
          "include": "#variable"
        },
        {
          "include": "#fn_op"
        },
        {
          "include": "#operator"
        },
        {
          "include": "#block"
        },
        {
          "include": "#array"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "match": "\\+=|-=|\\*=|/=|%=|==|!=|<=|>=",
          "name": "keyword.operator.assignment.compound.jspl"
        },
        {
          "match": "=|\\+|-|\\*|/|%|<|>",
          "name": "keyword.operator.jspl"
        }
      ]
    },
    "variable": {
      "match": "(?:\\$[a-zA-Z_][a-zA-Z0-9_]*|[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*(\\=|\\+\\=|-\\=|\\*\\=|/=|global)))",
      "name": "variable.name.jspl"
    },
    "fn_op": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "support.function.jspl"
    },
    "constant": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.jspl"
        },
        {
          "match": "-?\\d+(\\.\\d+)?([eE][-+]?\\d+)?",
          "name": "constant.numeric.jspl"
        },
        {
          "match": "\\\"(?:(\\\\.)|[^\\\"])*\\\"",
          "name": "string.quoted.double.jspl"
        }
      ]
    },
    "call": {
      "begin": "(?:(define)|(while|ret|GUI|if|scope|break|continue)|(Int|Float|Bool|Str|Null)|([a-zA-Z_][a-zA-Z0-9_]*))\\s*(\\()",
      "beginCaptures": {
        "1": {
          "name": "storage.type.jspl"
        },
        "2": {
          "name": "keyword.control.jspl"
        },
        "3": {
          "name": "support.type.primitive.jspl"
        },
        "4": {
          "name": "support.function.jspl"
        },
        "5": {
          "name": "punctuation.section.group.begin.jspl"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.group.end.jspl"
        }
      },
      "patterns": [
        {
          "include": "#all_expressions"
        },
        {
          "match": ",",
          "name": "punctuation.separator.jspl"
        }
      ]
    },
    "block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.block.begin.jspl"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.jspl"
        }
      },
      "patterns": [
        {
          "include": "#type_param_decl"
        },
        {
          "include": "#all_expressions"
        }
      ]
    },
    "type_param_decl": {
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)\\s*(Int|Float|Bool|Str|Null)",
      "captures": {
        "1": {
          "name": "variable.parameter.jspl"
        },
        "2": {
          "name": "keyword.operator.type.jspl"
        },
        "3": {
          "name": "support.type.primitive.jspl"
        }
      }
    },
    "type_primitive": {
      "match": "\\b(Int|Float|Bool|Str|Null)\\b",
      "name": "support.type.primitive.jspl"
    }
  }
}