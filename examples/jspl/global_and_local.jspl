# this program returns 1000.
define(param_type_test, { a: Null; b: Int; c: Bool; d: Str; e: Float }, Int, {
  if([ $c, while( 0 < $b, {
    print($d)
    b -= 1
  })])
  Int($e)
})

x = param_type_test(null, 2, true, "test\n", 6.9)
g_a global null
g_b global 7
g_c global false
g_e global 999.999
{ Int($g_e) + $g_b } - $x
