# This program performs `or`, `nand`, and `xor` operations
# on two arguments: true and false.
# If each operation evaluates to true,
# The name of the operation is printed.
# Therefore, all operations will be printed.

flag_true = true
flag_false = false

if([    $flag_false or  $flag_true,  print("or\n") ])
if([not($flag_false and $flag_true), print("nand\n")])
if([    $flag_false xor $flag_true,  print("xor\n")])
